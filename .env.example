# Copy to .env and adjust as needed. All values have safe defaults.

# Optional local LLM (Ollama). Off by default; the deterministic grounded
# generator is used when this is false.
USE_OLLAMA=false
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_TIMEOUT_S=15

# Retrieval
RETRIEVAL_TOP_K=4
LOW_CONFIDENCE_THRESHOLD=0.12

# Cost model (only used for the $/100 tickets estimate in evaluation)
COST_PER_1K_INPUT=0.0
COST_PER_1K_OUTPUT=0.0

# Paths
DATABASE_URL=sqlite:///./ticket_triage.db
DATA_DIR=./data

# CORS origins allowed to call the API (comma-separated). Defaults to the
# Next.js dev server.
CORS_ORIGINS=http://localhost:3000
